{
  "name": "@genosyn/home",
  "version": "0.0.1",
  "private": true,
  "description": "Genosyn marketing site",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.server.json && vite build",
