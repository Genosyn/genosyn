# vLLM model server configuration for Genosyn.
# Copy this file to `.env` (same directory) and edit, then `docker compose up -d`.
# `genosyn vllm up` writes and manages this file for you — you only need to edit
# it by hand if you run docker compose directly.

# ---- Model ----------------------------------------------------------------

# Any HuggingFace repo id vLLM can serve. This exact string is also what you
# type into Genosyn's "Model id" field.
#   Tool-capable picks: Qwen/Qwen2.5-Coder-32B-Instruct, meta-llama/Llama-3.3-70B-Instruct
VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Tool-call parser — MUST match the model family or the agent never sees tool
# calls: `hermes` for Qwen, `llama3_json` for Llama 3.x, `mistral` for Mistral.
VLLM_TOOL_PARSER=hermes

# Max context length. Genosyn injects Soul + Skills + the tool catalog every
# turn, so keep this at 32k+ for real work.
VLLM_MAX_MODEL_LEN=32768

# ---- Hardware -------------------------------------------------------------

# Fraction of each GPU's memory vLLM may claim (0.0–1.0).
VLLM_GPU_UTIL=0.90

# Shard the model across this many GPUs. 1 for a single card; set to your GPU
# count for models that don't fit on one (e.g. 70B → 4, a 1T MoE → 8).
VLLM_TP=1

# ---- Access ---------------------------------------------------------------

# Port to expose the OpenAI-compatible API on. Genosyn connects to
# http://<this-host>:<port>/v1
VLLM_PORT=8000

# HuggingFace token — required for gated weights (Llama, gated Qwen). Blank
# is fine for openly-licensed models.
HUGGING_FACE_HUB_TOKEN=

# Bearer token clients must send. STRONGLY recommended whenever the port is
# reachable off-host. Paste the same value into Genosyn's "API key" field.
VLLM_API_KEY=

# ---- Advanced -------------------------------------------------------------

# Pin a specific vLLM image tag instead of `latest`.
VLLM_TAG=latest

# Fixed container name (also the docker compose project scope).
VLLM_CONTAINER=genosyn-vllm

# Extra raw flags appended verbatim to the vllm serve command, e.g.
# "--quantization awq --kv-cache-dtype fp8".
VLLM_EXTRA_ARGS=
