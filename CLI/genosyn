                         --tag <tag>          vllm/vllm-openai image tag
  status               Show container state, readiness, and the connect URL.
  logs [-f] [--tail N] Show server logs. -f follows.
  down [--purge]       Stop the server. --purge also deletes the model cache.

${C_BOLD}Requires on the host:${C_RESET} an NVIDIA GPU + driver + the
nvidia-container-toolkit, and Docker Compose. See
https://genosyn.com/docs/open-source-models

${C_BOLD}Examples:${C_RESET}
  genosyn vllm up --model Qwen/Qwen2.5-Coder-32B-Instruct --api-key \$(openssl rand -hex 24)
  genosyn vllm up --model meta-llama/Llama-3.3-70B-Instruct --tp 4 --parser llama3_json --hf-token hf_xxx
  genosyn vllm status
  genosyn vllm logs -f
  genosyn vllm down
EOF
}

# `genosyn vllm <subcommand>` — namespace for the self-hosted model server.
cmd_vllm() {
  if [ $# -eq 0 ]; then
    cmd_vllm_help
    return 0
  fi
  local sub="$1"; shift
  case "${sub}" in
    up|start)       cmd_vllm_up     "$@" ;;
    down|stop)      cmd_vllm_down   "$@" ;;
    status|ps)      cmd_vllm_status "$@" ;;
    logs|log)       cmd_vllm_logs   "$@" ;;
    help|-h|--help) cmd_vllm_help ;;
    *) die "Unknown vllm subcommand: ${sub}. Run 'genosyn vllm help' for usage." ;;
  esac
}

cmd_version() {
  printf 'genosyn cli  %s\n' "${CLI_VERSION}"
  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1 && container_exists; then
    local image_ref
    image_ref="$(docker inspect --format '{{.Config.Image}}' "${NAME}" 2>/dev/null || true)"
    [ -n "${image_ref}" ] && printf 'container    %s\n' "${image_ref}"
  fi
}

cmd_help() {
  cat <<EOF
${C_BOLD}genosyn${C_RESET} — cluster maintainer for self-hosted Genosyn.

${C_BOLD}Usage:${C_RESET}
  genosyn <command> [flags]

${C_BOLD}Commands:${C_RESET}
  install              Pull the image and start the container (idempotent).
  upgrade              Self-upgrade the CLI, pull the latest image, recreate
                       the container. Pass --no-self-upgrade to skip the
                       script update.
  self-upgrade         Update only the genosyn CLI script in place.
  start                Start a stopped container.
  stop                 Stop the running container.
  restart              Stop, then start.
  status               Show container state, image, volume, and URL.
  logs [-f] [--tail N] Show container logs. -f follows.
  backup [--out FILE]  Tarball the data volume (default: timestamped file in cwd).
  restore <FILE> [-y]  Restore a backup tarball. Destructive; prompts unless -y.
  uninstall [--purge]  Remove the container. --purge also deletes the data volume.
  prune [--dry-run]    Remove orphaned Genosyn images left over from prior upgrades.
  vllm <subcommand>    Run a self-hosted, OpenAI-compatible model server (vLLM)
                       on a GPU host and connect an employee to it. Run
                       'genosyn vllm help' for up/status/logs/down.
  user <subcommand>    Manage human users. Run 'genosyn user help' for the
                       list, reset-password, and delete subcommands.
  version              Print CLI and container image versions.
  help                 Show this message.

${C_BOLD}Common flags (any command):${C_RESET}
  --port <n>           Host port (default: 8471, env: GENOSYN_PORT)
  --name <s>           Container name (default: genosyn, env: GENOSYN_NAME)
  --volume <s>         Data volume (default: genosyn-data, env: GENOSYN_VOLUME)
  --image <ref>        Image reference (default: ghcr.io/genosyn/app:latest,
                       env: GENOSYN_IMAGE)

${C_BOLD}Examples:${C_RESET}
  genosyn install --port 9000
  genosyn upgrade
  genosyn logs -f --tail 100
  genosyn backup --out ~/backups/genosyn-\$(date +%F).tar.gz
  genosyn restore ~/backups/genosyn-2026-04-22.tar.gz
  genosyn user list
  genosyn user reset-password alice@example.com
  genosyn user delete alice@example.com
  genosyn vllm up --model Qwen/Qwen2.5-Coder-32B-Instruct --api-key \$(openssl rand -hex 24)
  genosyn uninstall --purge

Docs: https://genosyn.com  •  Source: https://github.com/genosyn/genosyn
EOF
}

# ---------- dispatch ----------

main() {
  if [ $# -eq 0 ]; then
    cmd_help
    exit 0
  fi

  local sub="$1"; shift
  case "${sub}" in
    install)           cmd_install   "$@" ;;
    upgrade|update)    cmd_upgrade   "$@" ;;
    start)             cmd_start     "$@" ;;
    stop)              cmd_stop      "$@" ;;
    restart)           cmd_restart   "$@" ;;
    status|ps)         cmd_status    "$@" ;;
    logs|log)          cmd_logs      "$@" ;;
    backup)            cmd_backup    "$@" ;;
    restore)           cmd_restore   "$@" ;;
    uninstall|remove)  cmd_uninstall "$@" ;;
    prune|clean)       cmd_prune     "$@" ;;
    vllm)              cmd_vllm      "$@" ;;
    user)              cmd_user      "$@" ;;
    # Back-compat aliases for the pre-`user`-namespace commands.
    users)             cmd_users     "$@" ;;
    reset-password)    cmd_reset_password "$@" ;;
    self-upgrade|self-update) cmd_self_upgrade "$@" ;;
    version|--version|-v) cmd_version ;;
    help|--help|-h)    cmd_help ;;
    *) die "Unknown command: ${sub}. Run 'genosyn help' for usage." ;;
  esac
}

# Run unless we're being sourced -- test-genosyn.sh sources this file to
# exercise the pure helpers without docker. BASH_SOURCE is unset when the
# script is fed to bash on stdin, where we're definitely not sourced, so it
# defaults to $0 and main still runs.
if [ "${BASH_SOURCE[0]:-${0}}" = "${0}" ]; then
  main "$@"
fi
