{
  "name": "genosyn-app",
  "version": "0.1.0",
  "private": true,
  "description": "Genosyn App — run companies autonomously with AI employees",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore='**/vite.config.*' --ignore='client/**' --ignore='dist/**' --ignore='data/**' server/index.ts",
    "postinstall": "node scripts/rebuild-node-pty.mjs",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.server.json && mkdir -p dist/server/mcp-genosyn && cp server/mcp-genosyn/*.mjs dist/server/mcp-genosyn/",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "typeorm": "tsx ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d ormconfig.ts",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- migration:run -d ormconfig.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d ormconfig.ts",
    "migration:show": "npm run typeorm -- migration:show -d ormconfig.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@clickhouse/client": "^1.18.3",
    "@noble/hashes": "^1.4.0",
    "@types/archiver": "^7.0.0",
    "@types/unzipper": "^0.10.11",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.1.2",
    "cookie": "^1.1.1",
    "cookie-session": "^2.1.0",
    "cron-parser": "^4.9.0",
    "cronstrue": "^2.50.0",
    "dompurify": "^3.1.6",
    "express": "^4.21.0",
    "keygrip": "^1.1.0",
    "lucide-react": "^0.445.0",
    "marked": "^14.1.2",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "node-cron": "^3.0.3",
    "node-pty": "^1.0.0",
    "nodemailer": "^6.9.15",
    "nostr-tools": "^2.7.2",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "slugify": "^1.6.6",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "unzipper": "^0.12.3",
    "ws": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie": "^0.6.0",
    "@types/cookie-session": "^2.0.49",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/keygrip": "^1.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.5.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.7"
  }
}
